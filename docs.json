{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Mint Starter Kit",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "docs/index",
                  "docs/quickstart",
                  "docs/development"
                ]
              },
              {
                "group": "Customization",
                "pages": [
                  "docs/essentials/settings",
                  "docs/essentials/navigation"
                ]
              },
              {
                "group": "Writing content",
                "pages": [
                  "docs/essentials/markdown",
                  "docs/essentials/code",
                  "docs/essentials/images",
                  "docs/essentials/reusable-snippets"
                ]
              },
              {
                "group": "AI tools",
                "pages": [
                  "docs/ai-tools/cursor",
                  "docs/ai-tools/claude-code",
                  "docs/ai-tools/windsurf"
                ]
              },
              {
                "group": "Implementation exercises",
                "pages": [
                  "docs/implementation-exercises/signed-webhooks",
                  "docs/implementation-exercises/async-export-jobs",
                  "docs/implementation-exercises/team-feature-flags"
                ]
              },
              {
                "group": "Lord of the Rings trivia",
                "pages": [
                  "docs/trivia/the-eagles-and-gandalf"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "API documentation",
                "pages": [
                  "docs/api-reference/introduction"
                ]
              },
              {
                "group": "OpenAPI reference tests",
                "pages": [
                  "docs/api-reference/openapi-test/index",
                  "docs/api-reference/openapi-test/relative",
                  "docs/api-reference/openapi-test/absolute",
                  "docs/api-reference/openapi-test/same-dir",
                  "docs/api-reference/openapi-test/remote"
                ]
              },
              {
                "group": "Endpoint examples",
                "pages": [
                  "docs/api-reference/endpoint/get",
                  "docs/api-reference/endpoint/create",
                  "docs/api-reference/endpoint/delete",
                  "docs/api-reference/endpoint/webhook",
                  "docs/api-reference/endpoint/search",
                  "docs/api-reference/endpoint/academic-standards-search",
                  "docs/api-reference/endpoint/change-location",
                  "docs/api-reference/endpoint/hierarchy",
                  "docs/api-reference/endpoint/get-asset-proof",
                  "docs/api-reference/endpoint/get-pots"
                ]
              },
              {
                "group": "AsyncAPI documentation",
                "asyncapi": {
                  "source": "docs/api-reference/asyncapi.json"
                }
              }
            ]
          }
        ]
      },
      {
        "language": "fr",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Premiers pas",
                "pages": [
                  "docs/fr/index",
                  "docs/fr/quickstart",
                  "docs/fr/development"
                ]
              },
              {
                "group": "Personnalisation",
                "pages": [
                  "docs/fr/essentials/settings",
                  "docs/fr/essentials/navigation"
                ]
              },
              {
                "group": "Rédaction du contenu",
                "pages": [
                  "docs/fr/essentials/markdown",
                  "docs/fr/essentials/code",
                  "docs/fr/essentials/images",
                  "docs/fr/essentials/reusable-snippets"
                ]
              },
              {
                "group": "Outils d'IA",
                "pages": [
                  "docs/fr/ai-tools/cursor",
                  "docs/fr/ai-tools/claude-code",
                  "docs/fr/ai-tools/windsurf"
                ]
              },
              {
                "group": "Exercices d'implémentation",
                "pages": [
                  "docs/fr/implementation-exercises/signed-webhooks",
                  "docs/fr/implementation-exercises/async-export-jobs",
                  "docs/fr/implementation-exercises/team-feature-flags"
                ]
              },
              {
                "group": "Anecdotes du Seigneur des Anneaux",
                "pages": [
                  "docs/fr/trivia/the-eagles-and-gandalf"
                ]
              }
            ]
          },
          {
            "tab": "Référence d'API",
            "groups": [
              {
                "group": "Documentation d'API",
                "pages": [
                  "docs/fr/api-reference/introduction"
                ]
              },
              {
                "group": "Tests de référence OpenAPI",
                "pages": [
                  "docs/fr/api-reference/openapi-test/index",
                  "docs/fr/api-reference/openapi-test/relative",
                  "docs/fr/api-reference/openapi-test/absolute",
                  "docs/fr/api-reference/openapi-test/same-dir",
                  "docs/fr/api-reference/openapi-test/remote"
                ]
              },
              {
                "group": "Exemples de points de terminaison",
                "pages": [
                  "docs/fr/api-reference/endpoint/get",
                  "docs/fr/api-reference/endpoint/create",
                  "docs/fr/api-reference/endpoint/delete",
                  "docs/fr/api-reference/endpoint/webhook",
                  "docs/fr/api-reference/endpoint/search",
                  "docs/fr/api-reference/endpoint/academic-standards-search",
                  "docs/fr/api-reference/endpoint/change-location",
                  "docs/fr/api-reference/endpoint/hierarchy",
                  "docs/fr/api-reference/endpoint/get-asset-proof",
                  "docs/fr/api-reference/endpoint/get-pots"
                ]
              },
              {
                "group": "Documentation AsyncAPI",
                "asyncapi": {
                  "source": "docs/api-reference/asyncapi.json"
                }
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "api": {
    "params": {
      "expanded": "all"
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "metadata": {
    "timestamp": true
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
